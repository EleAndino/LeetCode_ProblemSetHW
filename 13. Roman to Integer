public class Solution 
{
    private Dictionary<char, int> RValues = new Dictionary<char, int>
    {
        {'I', 1}, {'V', 5}, {'X', 10}, {'L', 50}, {'C', 100}, {'D', 500}, {'M', 1000}
    };

    public int RomanToInt(string s) 
    {
        s = s.ToUpper();
        int rNum = 0;

        for (int i = 0; i <= s.Length - 1; i++) 
        {
            int value = RValues[s[i]];

            if (i + 1 <= s.Length - 1 && RValues[s[i + 1]] > value)
            {
                rNum -= value;
            }
            else
            {
                rNum += value;
            }
        }

        return rNum;
    }
}
